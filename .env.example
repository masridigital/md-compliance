# =============================================================================
# Masri Digital Compliance Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your deployment.

# --- Database ---
POSTGRES_USER=CHANGE_ME_DB_USER
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_DB=CHANGE_ME_DB_NAME
SQLALCHEMY_DATABASE_URI=postgresql://CHANGE_ME_DB_USER:CHANGE_ME_DB_PASSWORD@postgres/CHANGE_ME_DB_NAME

# --- Application ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_SECRET_KEY
APP_NAME=Masri Digital
HOST_NAME=localhost
VERSION=1.0.0
LOG_LEVEL=INFO
RESET_DB=no

# --- Branding ---
APP_PRIMARY_COLOR=#0066CC
APP_LOGO_URL=/static/img/logo.svg
APP_FAVICON_URL=/static/img/favicon.ico
SUPPORT_EMAIL=support@masridigital.com

# --- Email (SMTP) ---
MAIL_SERVER=smtp.googlemail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# --- Auth ---
DEFAULT_EMAIL=admin@example.com
DEFAULT_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ENABLE_SELF_REGISTRATION=false
ENABLE_GOOGLE_AUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ENABLE_MICROSOFT_AUTH=false
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Storage ---
STORAGE_METHOD=local
# S3
AWS_BUCKET=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=
# GCS
GCS_BUCKET=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# --- LLM / AI ---
LLM_ENABLED=false
LLM_NAME=openai
LLM_TOKEN=

# --- Notifications ---
TEAMS_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Microsoft Entra ID (Azure AD) ---
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# --- Scheduler ---
MASRI_SCHEDULER_ENABLED=true

# --- Feature Flags (prefix with FEATURE_) ---
# FEATURE_DARK_MODE=true
# FEATURE_MCP_API=true
