  "exemptions": [
    {
      "code": "500.19(a)(1)",
      "label": "Fewer than 20 employees (including independent contractors and affiliates)",
      "type": "limited",
      "threshold": "employee_count < 20",
      "scope_waived": ["500.4", "500.5", "500.6", "500.8", "500.10", "500.12", "500.14", "500.15", "500.16"]
    },
    {
      "code": "500.19(a)(2)",
      "label": "Less than $7.5M gross annual revenue from NY business (3-year average)",
      "type": "limited",
      "threshold": "avg_ny_revenue < 7500000",
      "scope_waived": ["500.4", "500.5", "500.6", "500.8", "500.10", "500.12", "500.14", "500.15", "500.16"]
    },
    {
      "code": "500.19(a)(3)",
      "label": "Less than $15M year-end total assets (including affiliates)",
      "type": "limited",
      "threshold": "total_assets < 15000000",
      "scope_waived": ["500.4", "500.5", "500.6", "500.8", "500.10", "500.12", "500.14", "500.15", "500.16"]
    },
    {
      "code": "500.19(b)",
      "label": "Captive insurance companies that do not directly write insurance in NY",
      "type": "full",
      "threshold": "is_captive_insurance == true",
      "scope_waived": "*"
    },
    {
      "code": "500.19(c)",
      "label": "Does not operate, maintain, utilize, or control any Information Systems and does not control or possess NPI",
      "type": "limited",
      "threshold": "!operates_information_systems AND !holds_npi",
      "scope_waived": ["500.2", "500.3", "500.4", "500.5", "500.6", "500.7", "500.8", "500.10", "500.12", "500.13", "500.14", "500.15", "500.16"]
    },
    {
      "code": "500.19(d)",
      "label": "Only encrypted Nonpublic Information with no access to encryption keys",
      "type": "limited",
      "threshold": "only_encrypted_npi_no_keys == true",
      "scope_waived": ["500.6", "500.8", "500.13", "500.14", "500.15"]
    },
    {
      "code": "500.19(e)",
      "label": "Covered under a parent or affiliate DFS-licensed entity's cybersecurity program",
      "type": "full",
      "threshold": "covered_by_other_dfs_entity == true",
      "scope_waived": "*"
    }
  ],
